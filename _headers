/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# brand assets are content-stable, fingerprint optional
/brand/*
  Cache-Control: public, max-age=86400

# during pre-launch iteration, force revalidation each load
# (the CSS / JS are small and the assets list versioned via query
# strings in index.html, but we still want freshness for typed URLs)
/styles.css
  Cache-Control: no-cache, must-revalidate

/app.js
  Cache-Control: no-cache, must-revalidate

/
  Cache-Control: no-cache, must-revalidate
